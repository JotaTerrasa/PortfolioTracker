# Backend
SERVER_PORT=3001

# Vercel/Neon Postgres (production)
# In Vercel, add a Postgres/Neon integration to get this automatically.
DATABASE_URL=postgres://user:password@host/db

# Optional secret used by Vercel Cron when calling /api/snapshot
CRON_SECRET=your_random_secret

# Optional dashboard authentication
# If DASHBOARD_PASSWORD is set, /api/* requires a valid token from /api/auth/login
DASHBOARD_PASSWORD=your_dashboard_password
# Optional extra signing secret for auth tokens (recommended in production)
AUTH_SECRET=your_auth_signing_secret

# Exchange API keys
BINGX_API_KEY=your_bingx_api_key
BINGX_SECRET_KEY=your_bingx_secret_key
BITPANDA_API_KEY=your_bitpanda_api_key

# Optional manual average prices / cost basis overrides
# Pattern:
#   BINGX_AVG_PRICE_<SYMBOL>=0
#   BITPANDA_AVG_PRICE_<SYMBOL>=0
# Example:
# BINGX_AVG_PRICE_ASTER=0.88
# BITPANDA_AVG_PRICE_ASTER=1.85
